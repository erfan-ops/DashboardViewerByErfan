# Set default line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.py text
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.toml text
*.md text
*.sql text
*.env.example text
*.yml text
*.yaml text

# Declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.mp4 binary
*.pdf binary
*.zip binary
*.gz binary

# Python
*.py diff=python

# TypeScript/JavaScript
*.ts linguist-detectable
*.tsx linguist-detectable
*.js linguist-detectable
*.jsx linguist-detectable

# Mark frontend as vendored (reduces language stats on GitHub)
frontend/node_modules/* linguist-vendored
frontend/dist/* linguist-vendored

# Mark lock files as generated
package-lock.json linguist-generated
uv.lock linguist-generated

# Configuration files
*.config.js linguist-detectable
*.config.ts linguist-detectable
vite.config.ts linguist-detectable
tailwind.config.js linguist-detectable

# Documentation
*.md linguist-documentation
